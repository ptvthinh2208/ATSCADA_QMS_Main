@page "/countercontrol/{CounterId:int}"
@layout CountersControlLayout
@inject IQueueApiClient QueueApiClient

<div class="queue-call-interface">
    <!-- Main Content -->
    <div class="main-content">
        <!-- Teller Info Section -->
        <div class="row mt-1 justify-content-center">
            <div class="col-md-12">
                <div class="teller-info-card align-items-center">
                    <div class="teller-image-wrapper">
                        <img src="img/call-center-customer-service.jpg" class="rounded-circle teller-image" alt="Teller Image">
                    </div>
                    <div class="teller-info ml-3">
                        <AuthorizeView>
                            <Authorized>
                                <h5 class="teller-name">@context.User.Identity!.Name</h5>
                            </Authorized>
                        </AuthorizeView>
                        @*<p class="service-info">@counters.Name</p> *@
                        <p class="teller-id">
                            <a href="./">
                                <i class="fa-solid fa-right-from-bracket"></i> Trang Chủ
                            </a>
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Queue Number and Customer Info -->
        <div style="margin-bottom:15px" class="row mt-4 justify-content-center">
            <div class="col-md-12">
                <!-- Alert for Currently Serving -->
                <div class="alert alert-warning text-center">
                    <strong>SỐ ĐANG PHỤC VỤ</strong>
                    <h2 class="display-4 font-weight-bold">@counters.Code@counters.CurrentNumber.ToString("D3")</h2>
                </div>
                <!-- Customer Information Card -->
                @if (currentClient != null)
                {
                    <div class="card p-3 shadow">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 style="padding-left: 14px;" class="card-title mb-0">Thông Tin Khách Hàng</h5>
                        </div>
                        <div class="card-body">
                            <p><strong>Họ và tên :</strong> @(currentClient?.FullName ?? "Trống")</p>
                            <p><strong>Số điện thoại :</strong>@(currentClient?.PhoneNumber ?? "Trống")</p>
                            <p><strong>Thời gian lấy phiếu :</strong> @currentClient.PrintTime.ToString("HH:mm, dd/MM/yyyy")</p>
                            <p>
                                <strong>Trạng thái :</strong>
                                <span class="status-@currentClient?.Status?.ToLower()">
                                    @(currentClient?.Status switch
                                    {
                                        "Missed" => "Bỏ qua",
                                        "Completed" => "Hoàn thành",
                                        "Processing" => "Đang xử lý",
                                        _ => "Không xác định"
                                    })
                                </span>
                            </p>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="action-buttons-container">
            <!-- Call Next Button -->
            <button class="btn btn-primary btn-lg" disabled="@isButtonDisabled" @onclick="CallNextTicket">
                Gọi Số Tiếp Theo
            </button>

            <!-- Skip and Call Again Buttons -->
            <div class="secondary-buttons">
                <button class="btn btn-secondary btn-block" disabled="@isButtonDisabled" type="button" @onclick="() => UpdateStatusMissed(currentClient!)" style="width:100%">
                    Bỏ Qua
                </button>
                <button class="btn btn-call-again btn-block" type="button" style="width:100%" @onclick="CallCurrentNumberAgain">
                    Gọi Lại
                </button>
            </div>
        </div>
    </div>

    <!-- Sidebar Content -->
    <div class="sidebar-content">
        <div class="queue-sidebar">
            <div class="card">
                <div class="card-body">
                    <!-- Status Section -->
                    <div class="status-section mb-4">
                        <div class="status-item d-flex justify-content-between filterStatus @(selectedStatus == QueueStatus.Waiting ? "active-status" : "")" @onclick="() => ChangeStatus(QueueStatus.Waiting)">
                            <span>&#9650; Danh sách khách hàng chờ</span>
                            <span class="badge badge-waiting">@listClientOnQueue.Count(c => c.Status == "Waiting")</span>
                        </div>
                        <div class="status-item d-flex justify-content-between filterStatus @(selectedStatus == QueueStatus.Completed ? "active-status" : "")" @onclick="() => ChangeStatus(QueueStatus.Completed)">
                            <span>&#9650; Danh sách khách hàng đã phục vụ</span>
                            <span class="badge badge-completed">@listClientOnQueueByCounterId.Count(c => c.Status == "Completed")</span>
                        </div>
                        <div class="status-item d-flex justify-content-between filterStatus @(selectedStatus == QueueStatus.Missed ? "active-status" : "")" @onclick="() => ChangeStatus(QueueStatus.Missed)">
                            <span>&#9650; Danh sách khách hàng bị qua lượt</span>
                            <span class="badge badge-serving">@listClientOnQueue.Count(c => c.Status == "Missed")</span>
                        </div>
                    </div>

                    <!-- Clients List -->
                    @if (filteredQueue != null && filteredQueue.Any())
                    {
                        @foreach (var clients in filteredQueue)
                        {
                            <div class="queue-card">
                                <div class="queue-card p-3 shadow-sm rounded">
                                    <!-- Display Name with OrderNumber Tag -->
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <div class="d-flex align-items-center">
                                            <h5 class="mb-0">Số Thứ Tự </h5>
                                            <span class="order-number-badge ms-3">@counters.Code@clients.OrderNumber.ToString("D3")</span>
                                        </div>
                                        <!-- Float Wait Time to the right -->
                                        @if (clients.Status == "Waiting")
                                        {
                                            <div class="d-flex align-items-center ms-auto">
                                                <button class="btn btn-secondary" disabled="@isButtonCancelDisabled" type="button" style="width:100%" @onclick="() => ShowDeleteConfirmation(clients)">
                                                    <i class="fa fa-trash"></i>
                                                </button>
                                            </div>
                                        }
                                        else if (clients.Status == "Completed")
                                        {
                                            <div class="status-badge d-flex align-items-center ms-auto">
                                                <i class="fa-solid fa-check me-1"></i>
                                                Completed
                                            </div>
                                        }
                                        else if (clients.Status == "Missed")
                                        {
                                            <div class="d-flex align-items-center ms-auto">
                                                <button class="btn btn-call-again" type="button" style="width:100%" @onclick="()=>UpdateStatusWaiting(clients)">
                                                    <i class="fa-solid fa-undo"></i>
                                                </button>
                                            </div>
                                        }
                                    </div>
                                    <!-- Tên nghiệp vụ -->
                                    @* <div class="d-flex justify-content-between align-items-center mb-2">
                                        <div class="d-flex align-items-center">
                                            <div class="service-name-container">
                                                <h6 class="service-name mb-0">@clients.NameQueueItem</h6>
                                            </div>
                                        </div>

                                    </div> *@
                                    <!-- STT with Priority Icon -->
                                    <div class="row">
                                        <div class="col-3 text-muted">Ưu Tiên</div>
                                        <div class="col-6 clerk-info d-flex align-items-center">
                                            @if (clients.Priority == false)
                                            {
                                                <i class="fa-solid fa-star" @onclick="() => TogglePriority(clients)"></i>
                                            }
                                            else
                                            {
                                                <i class="fa-solid fa-star me-2 text-warning" @onclick="() => TogglePriority(clients)"></i>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted p-4">
                            <i class="fa-solid fa-inbox fa-2x mb-2"></i>
                            <p>Không có khách hàng nào</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirm Modal -->
@if (isDeleteConfirmModal)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" id="deleteModal"
         aria-labelledby="deleteModalLabel" aria-hidden="true"
         style="background-color: rgba(0, 0, 0, 0.5);">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="deleteModalLabel">Xoá số thứ tự</h5>
                    <button type="button" class="btn-close" @onclick="CloseConfirmation" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    Bạn có chắc là muốn xoá SỐ THỨ TỰ này không? <br />
                    <strong>Lưu ý:</strong> Hành động này sẽ không thể phục hồi!
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseConfirmation">Huỷ</button>
                    <button type="button" class="btn btn-danger" @onclick="DeleteConfirmed">Xác nhận xoá</button>
                </div>
            </div>
        </div>
    </div>
}

