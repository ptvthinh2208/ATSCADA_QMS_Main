@page "/report-detail/{ReportId:int}"
@using ATSCADA_Library.Entities
@attribute [Authorize(Roles = "Admin")]
@inject IQueueApiClient QueueApiClient
@inject IReportApiClient ReportApiClient
@if (listReportDetails == null)
{
    <span>
        Loading Report list ...
    </span>
}
else
{
    <div class="container mt-5">
        <div class="row mb-3 align-items-center">
            <!-- Breadcrumb -->
            <div class="col-12">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb" style="background-color: transparent;">
                        <li class="breadcrumb-item"><a href="/reports">Report</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Report Detail</li>
                    </ol>
                </nav>
            </div>
            <div class="col-md-4">
                
            </div>

            <div class="col-md-8 d-flex justify-content-start" style="gap: 10px;">
                @* <button class="btn btn-success" style="min-width: 120px;" @onclick='() => ExportToExcel(listReport,"Total_Statistics")'>Export</button>
                <button class="btn btn-primary" @onclick="ShowPerformanceModal">Performance Chart</button> *@

            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="thead-light">
                    <tr class="tr-hover">

                        <th @onclick="() => SortByColumn(nameof(Report.CreatedDate))">
                            Service Name

                        </th>
                        <th @onclick="() => SortByColumn(nameof(Report.TotalPrint))">
                            Total Number Print
                        </th>
                        <th @onclick="() => SortByColumn(nameof(Report.TotalCompleted))">
                            Total Number Completed

                        </th>
                        <th @onclick="() => SortByColumn(nameof(Report.TotalMissed))">
                            Total Number Missed

                        </th>
                        <th @onclick="() => SortByColumn(nameof(Report.TotalMissed))">
                            Total Number Cancel

                        </th>

                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in listReportDetails!)
                    {
                        <tr>

                            <td>@item.ServiceName</td>
                            <td>@item.TotalPrint</td>
                            <td>@item.TotalCompleted</td>
                            <td>@item.TotalMissed</td>
                            <td>@item.TotalCancel</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        
    </div>
}