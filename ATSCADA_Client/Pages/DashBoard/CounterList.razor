@page "/counterslist"
@using ATSCADA_Library.Entities
@attribute [Authorize(Roles = "Admin")]
@inject IQueueApiClient QueueApiClient
@if (ListCounter == null)
{
    <span>
        Loading Counter ...
    </span>
}
else
{
    <div class="container mt-5">
        <div class="row mb-3">
            <!-- Cột 1: Show entries -->
            <div class="col-12 col-md-3 mb-2 mb-md-0 d-flex align-items-center">
                <label for="entries" class="form-label mb-0 me-2">Show</label>
                <PageSizeSelector PageSizeChanged="OnPageSizeChanged" />
                <span class="ms-1">entries</span>
            </div>

            <!-- Cột 2: Add New Counter button -->
            <div class="col-12 col-md-4 mb-2 mb-md-0 text-md-start text-center">
                <button class="btn btn-addnew" @onclick="OpenModal">
                    <i class="fa fa-plus"></i> Add New Counter
                </button>
            </div>

            <!-- Cột 3: Search bar -->
            <div class="col-12 col-md-5">
                <div class="input-group">
                    <input @oninput="OnSearch" type="text" class="form-control" placeholder="Search by Counter Name" aria-label="Search">
                    <span class="input-group-text">
                        <i class="bi bi-search"></i> <!-- Bootstrap Icon -->
                    </span>
                </div>
            </div>
        </div>


        <div class="table-responsive">
            <table class="table table-striped" style="white-space: nowrap;">
                <thead>
                    <tr class="tr-hover">
                        <th @onclick="() => SortByColumn(nameof(Counter.Code))">
                            Code
                        </th>
                        <th @onclick="() => SortByColumn(nameof(Counter.Name))">
                            Counter Name

                        </th>
                        <th @onclick="() => SortByColumn(nameof(Counter.ServiceDescription))">
                            Service Name
                        </th>
                        <th @onclick="() => SortByColumn(nameof(Counter.IsActive))">
                            Status
                        </th>
                        <th>#</th>

                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in ListCounter!)
                    {
                        <tr>
                            <td>@item.Code</td>
                            <td>@item.Name</td>
                            <td>@GetDescriptionService(@item.ServiceID)</td>
                            <td><StatusLabel IsActive="@item.IsActive" OnClick="@(() => ToggleIsActive(item))" /></td>
                            <td>

                                <button class="btn btn-sm btn-edit" @onclick="() => OpenEditModal(item)">
                                    <i class="fa fa-pencil"></i>
                                </button>
                                
                            </td>

                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @* <div style="float:left" class="d-flex justify-content-between align-items-center mt-3">
            <span>Showing @FromRecord to @ToRecord of @TotalRecords entries</span>
        </div> *@
        <div style="float:right" class="d-flex justify-content-between align-items-center mt-3">
            <Pagination MetaData="MetaData" Spread="2" SelectedPage="SelectedPage"></Pagination>
        </div>
    </div>
}

<!-- Modal Add New-->
<div class="modal fade @(isModalVisible ? "show d-block" : "")" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add New Counter</h5>
                <button type="button" class="btn-close" @onclick="CloseModal"></button>
            </div>
            <div class="modal-body">
                <EditForm Model="@newCounter" OnValidSubmit="HandleValidSubmitCreate">
                    <DataAnnotationsValidator />
                    <div class="mb-3">
                        <p for="name" class="form-label">Counter Code</p>
                        <InputText id="name" class="form-control" @bind-Value="newCounter.Code" />
                        <ValidationMessage For="@(() => newCounter.Code)" />
                    </div>
                    <div class="mb-3">
                        <p for="name" class="form-label">Counter Name</p>
                        <InputText id="name" class="form-control" @bind-Value="newCounter.NameCounter" />
                        <ValidationMessage For="@(() => newCounter.NameCounter)" />
                    </div>
                   
                    <div class="mb-3">
                        <p for="phone">Service</p>
                        <InputSelect @bind-Value="newCounter.ServiceId" id="numberSelect" class="form-control">
                            <option value="0">--Select Service--</option>
                            @foreach (var item in listService!)
                            {
                                <option value="@item.Id">@item.Description (@item.Name)</option>
                            }
                            @* @foreach (var item in GetAvailableServices())
                            {
                                <option value="@item.Id">@item.Description (@item.Name)</option>
                            } *@
                        </InputSelect>
                        @* @if (GetAvailableServices() == null || !GetAvailableServices().Any())
                        {
                            <span style="color:red;font-weight:bold">No service can be selected now!</span>
                        } *@
                    </div>
                    <div style="float:right">
                        <button @onclick="CloseModal" class="btn btn-secondary">Cancel</button>
                        <button type="submit" class="btn btn-primary">Add New</button>
                    </div>

                </EditForm>
            </div>
        </div>
    </div>
</div>

<!-- Edit Counter Modal -->
@if (isEditModalVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Counter</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="@editCounter" OnValidSubmit="HandleValidSubmitUpdate">
                        <DataAnnotationsValidator />
                        <div class="mb-3">
                            <label for="name" class="form-label">Counter Code</label>
                            <InputText id="name" class="form-control" @bind-Value="editCounter.Code" />
                            <ValidationMessage For="@(() => newCounter.Code)" />
                        </div>
                        <div class="mb-3">
                            <label for="name" class="form-label">Counter Name</label>
                            <InputText id="name" class="form-control" @bind-Value="editCounter.NameCounter" />
                            <ValidationMessage For="@(() => newCounter.NameCounter)" />
                        </div>
                       
                        <div class="mb-3">
                            <label for="phone">Service :</label>
                            <InputSelect @bind-Value="editCounter.ServiceId" id="numberSelect" class="form-control">
                                @* @foreach (var item in GetAvailableServices().Concat(listService.Where(q => q.Id == editCounter.ServiceId)))
                                {
                                    <option value="@item.Id">@item.Description</option>
                                } *@
                                @foreach (var item in listService!)
                                {
                                    <option value="@item.Id">@item.Description</option>
                                }
                            </InputSelect>
                        </div>
                        <div style="float:right">
                            <button @onclick="CloseModal" class="btn btn-secondary">Cancel</button>
                            <button type="submit" class="btn btn-primary">Save Changes</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}