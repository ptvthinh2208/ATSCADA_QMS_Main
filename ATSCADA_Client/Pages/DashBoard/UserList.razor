@page "/userslist"
@using ATSCADA_Library.Entities
@attribute [Authorize(Roles = "Admin")]
@inject IUserApiClient UserApiClient
@inject ISystemRoleApiClient SystemRoleApiClient
@if (ListUsers == null)
{
    <span>
        Loading Queue item...
    </span>
}
else
{
    <div class="container mt-5">
        <div class="row mb-3">
            <!-- Cột 1: Show entries -->
            <div class="col-12 col-md-3 mb-2 mb-md-0 d-flex align-items-center">
                <label for="entries" class="form-label mb-0 me-2">Show</label>
                <PageSizeSelector PageSizeChanged="OnPageSizeChanged" />
                <span class="ms-1">entries</span>
            </div>

            <!-- Cột 2: Add New Counter button -->
            <div class="col-12 col-md-4 mb-2 mb-md-0 text-md-start text-center">
                <button class="btn btn-addnew" @onclick="OpenModal">
                    <i class="fa fa-plus"></i> Add New User
                </button>
            </div>
            @*  <div class="col-md-2">
                <InputSelect @bind-Value="SearchBy" id="numberSelect" class="form-control">
                    <option value="">--Select--</option>
                    <option value="FullName">Full Name</option>
                    <option value="PhoneNumber">System Role</option>
                    <option value="DescriptionService">Name Counter</option>
                </InputSelect>
            </div> *@
            <!-- Cột 3: Search bar -->
            <div class="col-12 col-md-5">
                <div class="input-group">
                    <input @oninput="e => OnSearch(e, SearchBy)" type="text" class="form-control" placeholder="Search by Full Name" aria-label="Search">
                    <span class="input-group-text">
                        <i class="bi bi-search"></i> <!-- Bootstrap Icon -->
                    </span>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-striped" style="white-space: nowrap;">
                <thead>
                    <tr class="tr-hover">
                        
                        <th @onclick="() => SortByColumn(nameof(ApplicationUser.FullName))">
                            Full Name
                            
                        </th>
                        <th @onclick="() => SortByColumn(nameof(ApplicationUser.UserName))">
                            Email
                           
                        </th>
                        <th @onclick="() => SortByColumn(nameof(ApplicationUser.SystemRoleId))">
                            System Role
                           
                        </th>
                        <th @onclick="() => SortByColumn(nameof(ApplicationUser.CounterId))">
                            Name Counter
                        </th>
                        <th>#</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in ListUsers!)
                    {
                        <tr>
                            
                            <td>@item.FullName</td>
                            <td>@item.UserName</td>
                            <td>
                                @(item.SystemRoleId == 1 ? "Admin" : "Queue Manager")
                            </td>
                            <td>
                                @GetNameCounter(item.CounterId)
                            </td>
                            <td>

                                <button class="btn btn-sm btn-edit" @onclick="() => OpenEditModal(item)">
                                    <i class="fa fa-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-delete" @onclick="() => ShowDeleteConfirmation(item)">
                                    <i class="fa fa-trash" aria-hidden="true"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div style="float:right" class="d-flex justify-content-between align-items-center mt-3">
            <Pagination MetaData="MetaData" Spread="2" SelectedPage="SelectedPage"></Pagination>
        </div>
    </div>
}

<!-- Modal Add New-->
<div class="modal fade @(isModalVisible ? "show d-block" : "")" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 style="font-weight:bold" class="modal-title">Add New User</h5>
                <button type="button" class="btn-close" @onclick="CloseModal"></button>
            </div>
            <div class="modal-body">
                <EditForm Model="@newUser" OnValidSubmit="HandleValidSubmitCreate">
                    <DataAnnotationsValidator />
                    <div class="mb-3">
                        <p for="fullname">Full Name</p>
                        <InputText id="fullname" class="form-control" @bind-Value="newUser.FullName" />
                        <ValidationMessage For="@(() => newUser.FullName)" />
                    </div>
                    <div class="mb-3">
                        <p for="username">User Name</p>
                        <InputText id="username" class="form-control" @bind-Value="newUser.UserName" />
                        <ValidationMessage For="@(() => newUser.UserName)" />
                    </div>
                    <div class="mb-3">
                        <p for="password">Password</p>
                        <InputText  id="password" class="form-control" @bind-Value="newUser.Password" />
                    </div>
                    <div class="mb-3">
                        <InputRadioGroup @bind-Value="newUser.SystemRoleId">
                            @foreach (var item in ListRoles)
                            {
                                <div class="form-check form-check-text">
                                    <InputRadio class="form-check-input" Value="@item.Id" />
                                    <p class="form-check-label">@item.Name</p>
                                    <small>@item.Description</small>
                                </div>
                            }
                        </InputRadioGroup>
                    </div>
                    @if (newUser.SystemRoleId == 2)
                    {
                        <div class="mb-3">
                            <InputSelect @bind-Value="newUser.CounterId" id="numberSelect" class="form-control">
                                @foreach (var item in listCounter!)
                                {
                                    <option value="@item.Id">@item.Name</option>
                                }
                            </InputSelect>
                        </div>
                    }
                    <div style="float:right">
                        <button @onclick="CloseModal" class="btn btn-secondary">Cancel</button>
                        <button type="submit" class="btn btn-primary">Add New</button>
                    </div>

                </EditForm>
            </div>
        </div>
    </div>
</div>

<!-- Edit Counter Modal -->
@if (isEditModalVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit User</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="@editUser" OnValidSubmit="HandleValidSubmitUpdate">
                        <DataAnnotationsValidator />
                        <div class="mb-3">
                            <p for="fullname">Full Name</p>
                            <InputText id="fullname" class="form-control" @bind-Value="editUser.FullName" />
                            <ValidationMessage For="@(() => editUser.FullName)" />
                        </div>
                        <div class="mb-3">
                            <p for="username">User Name</p>
                            <InputText id="username" class="form-control" @bind-Value="editUser.UserName" />
                            <ValidationMessage For="@(() => editUser.UserName)" />
                        </div>
                        
                        <div class="mb-3">
                            <InputRadioGroup @bind-Value="editUser.SystemRoleId">
                                @foreach (var item in ListRoles)
                                {
                                    <div class="form-check form-check-text">
                                        <InputRadio class="form-check-input" Value="@item.Id" />
                                        <p class="form-check-label">@item.Name</p>
                                        <small>@item.Description</small>
                                    </div>
                                }
                            </InputRadioGroup>
                        </div>
                        @if (editUser.SystemRoleId == 2)
                        {
                            <div class="mb-3">
                                <InputSelect @bind-Value="editUser.CounterId" id="numberSelect" class="form-control">
                                    @foreach (var item in listCounter!)
                                    {
                                        <option value="@item.Id">@item.Name</option>
                                    }
                                </InputSelect>
                            </div>
                        }
                        <div style="float:right">
                            <button @onclick="CloseModal" class="btn btn-secondary">Cancel</button>
                            <button type="submit" class="btn btn-primary">Confirm</button>
                        </div>

                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

<!-- Delete Confirm Modal -->
@if (isDeleteConfirmVisible)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" id="deleteModal" aria-labelledby="deleteModalLabel" aria-hidden="true" style="background-color: rgba(0, 0, 0, 0.5);">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="deleteModalLabel">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="CloseDeleteConfirmation" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    Are you sure you want to delete this User?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseDeleteConfirmation">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="DeleteConfirmed">Delete</button>
                </div>
            </div>
        </div>
    </div>
}