@page "/view"
@layout CountersMainLayout
@inject IQueueApiClient QueueApiClient
@inject IQueueSpeechApiClient QueueSpeechApiClient
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<script>
    // Hàm phát file .mp3 thông thường
    window.playIntroAudio = (mp3Url) => {
        return new Promise((resolve, reject) => {
            try {
                const intro = new Audio(mp3Url);
                intro.play().then(() => {
                    intro.onended = () => {
                        resolve(); // tiếp tục khi nhạc intro kết thúc
                    };
                }).catch(reject);
            } catch (error) {
                reject(error);
            }
        });
    };

    // Hàm phát base64 sau khi phát intro
    window.playBase64AudioWithIntro = async (introUrl, base64AudioUrl) => {
        try {
            await window.playIntroAudio(introUrl);
            await window.playBase64Audio(base64AudioUrl);
        } catch (err) {
            console.error("Audio play error:", err);
        }
    };

    // Hàm gốc phát base64
    window.playBase64Audio = (audioUrl) => {
        return new Promise((resolve, reject) => {
            try {
                var audio = new Audio(audioUrl);
                audio.play().then(() => {
                    audio.onended = () => {
                        resolve(); // Khi phát xong
                    };
                }).catch(reject);
            } catch (error) {
                reject(error);
            }
        });
    };
</script>
