@code {
    [Parameter]
    public bool IsActive { get; set; }  // Determines the status
    [Parameter]
    public EventCallback OnClick { get; set; }  // EventCallback to handle click events
    private string StatusText => IsActive ? "Active" : "Inactive"; // Conditionally set status text
    private string CssClass => IsActive ? "badge bg-success-gradient" : "badge bg-danger-gradient"; // Conditionally set CSS class
    private async Task HandleClick()
    {
        if (OnClick.HasDelegate)
        {
            await OnClick.InvokeAsync(null);
        }
    }
}

<span class="@CssClass" @onclick="HandleClick" style="cursor: pointer;">@StatusText</span>

<style>
    .status-label {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 4px;
        color: #fff;
        font-size: 14px;
        font-weight: bold;
        text-align: center;
    }

    .btn-success {
        background-color: #28a745; /* Green color for active status */
    }

    .btn-danger {
        background-color: #dc3545; /* Red color for inactive status */
    }

    .bg-success-gradient {
        background-color: #51cc8a;
        background-image: linear-gradient(45deg, #85dbad 0%, #49b87c 100%);
    }
    .bg-danger-gradient {
        background-color: #ef376e;
        background-image: linear-gradient(45deg, #f4739a 0%, #d73263 100%);
    }
</style>
